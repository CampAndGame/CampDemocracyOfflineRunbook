# Standalone-режим CampDemocracyService — переменные окружения.
# Скопируй этот файл в .env и заполни значения.
# .env НЕ коммитить в Git!

# Пароль локального админа (нужен для входа в админку через UI).
# Можно поставить любую строку, например stand2026.
ADMIN_LOCAL_PASSWORD=

# JWT secret для подписи admin-токенов. Длина >= 32 символа.
# Сгенерировать:
#   openssl rand -base64 32
ADMIN_LOCAL_JWT_SECRET=

# Опционально: пароль БД (если не задан — democracy_local_pass).
# DB_PASSWORD=
