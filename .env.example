# ==========================================================
#  Настройки стенда Democracy.
#  Скопируй этот файл в .env  (или запусти start.sh — он сделает это сам).
# ==========================================================

# ЕДИНСТВЕННОЕ, что нужно вписать — пароль для входа в админку (ведущий).
# Придумай свой, например: stand2026
ADMIN_LOCAL_PASSWORD=

# Технический секрет — НЕ трогай. start.sh подставит случайное значение сам.
ADMIN_LOCAL_JWT_SECRET=

# (необязательно) пароль БД. Оставь пустым — будет значение по умолчанию.
# DB_PASSWORD=
